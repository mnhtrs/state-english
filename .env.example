# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required for local development.
# Used server-side only by the Vite dev plugin (vite.config.ts).
# Never embedded in the browser bundle.
VITE_GEMINI_API_KEY="INSERT_YOUR_GEMINI_API_KEY_HERE"

# Optional. Leave empty for local dev.
# Set to your backend base URL when deploying.
# Example: https://api.statelish.app
VITE_API_BASE_URL=
